{
  "swagger": "2.0",
  "info": {
    "title": "Kurator API",
    "version": "1.0",
    "description": "REST API for Kurator: collections, items, search, external metadata lookup, session-based auth, bundled SQL migrations with first-boot bootstrap, and optional S3-backed image uploads."
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": ["http"],
  "securityDefinitions": {
    "SessionCookie": {
      "type": "apiKey",
      "name": "kurator_session",
      "in": "cookie"
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health check",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "additionalProperties": {"type": "string"}
            }
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Register",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/RegisterBody"}
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {"$ref": "#/definitions/User"}
          },
          "400": {"description": "Bad Request"},
          "409": {"description": "Conflict"}
        }
      }
    },
    "/api/v1/auth/beta/status": {
      "get": {
        "tags": ["auth"],
        "summary": "Beta access status",
        "produces": ["application/json"],
        "responses": {
          "200": {"description": "OK", "schema": {"type": "object"}}
        }
      }
    },
    "/api/v1/auth/beta/unlock": {
      "post": {
        "tags": ["auth"],
        "summary": "Unlock private beta (set cookie)",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/BetaUnlockBody"}
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"type": "object"}},
          "400": {"description": "Bad Request"},
          "404": {"description": "Not Found"}
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Login",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/LoginBody"}
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"type": "object"}},
          "401": {"description": "Unauthorized"},
          "500": {"description": "Server Error"}
        }
      }
    },
    "/api/v1/auth/login/2fa": {
      "post": {
        "tags": ["auth"],
        "summary": "Login (2FA)",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/Login2FABody"}
          }
        ],
        "responses": {
          "200": {"description": "OK"},
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "Logout",
        "responses": {
          "204": {"description": "No Content"}
        }
      }
    },
    "/api/v1/auth/forgot-password": {
      "post": {
        "tags": ["auth"],
        "summary": "Request password recovery code",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/ForgotPasswordBody"}
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"type": "object"}}
        }
      }
    },
    "/api/v1/auth/forgot-password/verify": {
      "post": {
        "tags": ["auth"],
        "summary": "Verify recovery code",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/VerifyForgotPasswordBody"}
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"type": "object"}},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/auth/forgot-password/reset": {
      "post": {
        "tags": ["auth"],
        "summary": "Reset password after recovery",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/ResetForgotPasswordBody"}
          }
        ],
        "responses": {
          "204": {"description": "No Content"},
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/me": {
      "get": {
        "tags": ["auth"],
        "summary": "Current user",
        "security": [{"SessionCookie": []}],
        "produces": ["application/json"],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/User"}},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not Found"}
        }
      },
      "patch": {
        "tags": ["auth"],
        "summary": "Update profile",
        "security": [{"SessionCookie": []}],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/PatchMeBody"}
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/User"}},
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/me/notifications/unread-count": {
      "get": {
        "tags": ["notifications"],
        "summary": "Unread in-app notification count",
        "description": "Lightweight poll endpoint for the activity bell badge. Does not return notification rows.",
        "security": [{"SessionCookie": []}],
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {"$ref": "#/definitions/NotificationUnreadCount"}
          },
          "401": {"description": "Unauthorized"},
          "500": {"description": "Internal Server Error"}
        }
      }
    },
    "/api/v1/me/2fa/setup": {
      "post": {
        "tags": ["auth"],
        "summary": "Start 2FA setup",
        "security": [{"SessionCookie": []}],
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {"$ref": "#/definitions/TwoFASetupResult"}
          },
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/me/2fa/enable": {
      "post": {
        "tags": ["auth"],
        "summary": "Enable 2FA",
        "security": [{"SessionCookie": []}],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/TwoFAEnableBody"}
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/User"}},
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/me/2fa/disable": {
      "post": {
        "tags": ["auth"],
        "summary": "Disable 2FA",
        "security": [{"SessionCookie": []}],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/TwoFADisableBody"}
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/User"}},
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/images": {
      "post": {
        "tags": ["images"],
        "summary": "Upload image",
        "security": [{"SessionCookie": []}],
        "consumes": ["multipart/form-data", "application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "file",
            "in": "formData",
            "type": "file",
            "description": "Image file"
          },
          {
            "name": "body",
            "in": "body",
            "schema": {"$ref": "#/definitions/ImageFromURLBody"}
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "properties": {"url": {"type": "string"}}
            }
          },
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"},
          "413": {"description": "Payload Too Large"},
          "503": {"description": "Service Unavailable"}
        }
      }
    },
    "/api/v1/users/search": {
      "get": {
        "tags": ["social"],
        "summary": "Search users",
        "produces": ["application/json"],
        "parameters": [
          {"name": "q", "in": "query", "required": true, "type": "string"}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {"type": "array", "items": {"$ref": "#/definitions/PublicUser"}}
          }
        }
      }
    },
    "/api/v1/collections": {
      "get": {
        "tags": ["collections"],
        "summary": "List collections",
        "produces": ["application/json"],
        "parameters": [
          {"name": "q", "in": "query", "type": "string"},
          {"name": "sort", "in": "query", "type": "string"},
          {"name": "has_description", "in": "query", "type": "string"},
          {"name": "page", "in": "query", "type": "integer"},
          {"name": "limit", "in": "query", "type": "integer"}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {"$ref": "#/definitions/CollectionListResult"}
          },
          "500": {"description": "Server Error"}
        }
      },
      "post": {
        "tags": ["collections"],
        "summary": "Create collection",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/CreateCollectionBody"}
          }
        ],
        "responses": {
          "201": {"description": "Created", "schema": {"$ref": "#/definitions/Collection"}},
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/collections/{id}/items.csv": {
      "get": {
        "tags": ["collections"],
        "summary": "Export collection items as CSV",
        "produces": ["text/csv"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"type": "string"}},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden"},
          "404": {"description": "Not Found"}
        }
      }
    },
    "/api/v1/collections/{id}/items/import": {
      "post": {
        "tags": ["collections"],
        "summary": "Import items from CSV",
        "consumes": ["multipart/form-data"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "file",
            "in": "formData",
            "required": true,
            "type": "file",
            "description": "CSV file"
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/ImportItemsResult"}},
          "400": {"description": "Bad Request"},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden"}
        }
      }
    },
    "/api/v1/collections/{id}": {
      "get": {
        "tags": ["collections"],
        "summary": "Get collection",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/Collection"}},
          "400": {"description": "Bad Request"},
          "404": {"description": "Not Found"},
          "500": {"description": "Server Error"}
        }
      }
    },
    "/api/v1/items": {
      "get": {
        "tags": ["items"],
        "summary": "List items",
        "produces": ["application/json"],
        "parameters": [
          {"name": "limit", "in": "query", "type": "integer"},
          {"name": "collection_id", "in": "query", "type": "integer", "format": "int64"}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/Item"}
            }
          },
          "400": {"description": "Bad Request"},
          "404": {"description": "Not Found"},
          "500": {"description": "Server Error"}
        }
      },
      "post": {
        "tags": ["items"],
        "summary": "Create item",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/ItemBody"}
          }
        ],
        "responses": {
          "201": {"description": "Created", "schema": {"$ref": "#/definitions/Item"}},
          "400": {"description": "Bad Request"}
        }
      }
    },
    "/api/v1/items/{id}": {
      "get": {
        "tags": ["items"],
        "summary": "Get item",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/Item"}},
          "400": {"description": "Bad Request"},
          "404": {"description": "Not Found"},
          "500": {"description": "Server Error"}
        }
      },
      "put": {
        "tags": ["items"],
        "summary": "Update item",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/ItemBody"}
          }
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/Item"}},
          "400": {"description": "Bad Request"},
          "404": {"description": "Not Found"}
        }
      },
      "delete": {
        "tags": ["items"],
        "summary": "Delete item",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "204": {"description": "No Content"},
          "400": {"description": "Bad Request"},
          "404": {"description": "Not Found"},
          "500": {"description": "Server Error"}
        }
      }
    },
    "/api/v1/search": {
      "get": {
        "tags": ["search"],
        "summary": "Search items",
        "produces": ["application/json"],
        "parameters": [
          {"name": "q", "in": "query", "type": "string"},
          {"name": "limit", "in": "query", "type": "integer"}
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"type": "object"}},
          "502": {"description": "Bad Gateway"}
        }
      }
    },
    "/api/v1/metadata/lookup": {
      "get": {
        "tags": ["metadata"],
        "summary": "Metadata lookup",
        "produces": ["application/json"],
        "parameters": [
          {"name": "q", "in": "query", "type": "string"},
          {"name": "query", "in": "query", "type": "string"},
          {"name": "category", "in": "query", "type": "string"},
          {"name": "provider", "in": "query", "type": "string"}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {"$ref": "#/definitions/MetadataLookupResult"}
          }
        }
      }
    }
  },
  "definitions": {
    "User": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "format": "int64"},
        "email": {"type": "string"},
        "display_name": {"type": "string"},
        "bio": {"type": "string"},
        "avatar_url": {"type": "string"},
        "two_factor_enabled": {"type": "boolean"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "RegisterBody": {
      "type": "object",
      "required": ["email", "password"],
      "properties": {
        "email": {"type": "string"},
        "password": {"type": "string"},
        "display_name": {"type": "string"}
      }
    },
    "BetaUnlockBody": {
      "type": "object",
      "properties": {
        "key": {"type": "string"}
      }
    },
    "LoginBody": {
      "type": "object",
      "required": ["email", "password"],
      "properties": {
        "email": {"type": "string"},
        "password": {"type": "string"}
      }
    },
    "Login2FABody": {
      "type": "object",
      "properties": {
        "pending_token": {"type": "string"},
        "code": {"type": "string"}
      }
    },
    "PatchMeBody": {
      "type": "object",
      "properties": {
        "display_name": {"type": "string"},
        "bio": {"type": "string"},
        "avatar_url": {"type": "string"}
      }
    },
    "TwoFASetupResult": {
      "type": "object",
      "properties": {
        "secret": {"type": "string"},
        "otpauth_url": {"type": "string"}
      }
    },
    "TwoFAEnableBody": {
      "type": "object",
      "properties": {"code": {"type": "string"}}
    },
    "TwoFADisableBody": {
      "type": "object",
      "properties": {"password": {"type": "string"}}
    },
    "ForgotPasswordBody": {
      "type": "object",
      "properties": {
        "email": {"type": "string"},
        "turnstile_token": {"type": "string"}
      }
    },
    "VerifyForgotPasswordBody": {
      "type": "object",
      "properties": {
        "email": {"type": "string"},
        "code": {"type": "string"},
        "turnstile_token": {"type": "string"}
      }
    },
    "ResetForgotPasswordBody": {
      "type": "object",
      "properties": {
        "reset_token": {"type": "string"},
        "password": {"type": "string"},
        "turnstile_token": {"type": "string"}
      }
    },
    "ImageFromURLBody": {
      "type": "object",
      "properties": {"url": {"type": "string"}}
    },
    "Item": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "format": "int64"},
        "collection_id": {"type": "integer", "format": "int64"},
        "title": {"type": "string"},
        "category": {"type": "string"},
        "metadata": {"type": "object"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "ItemBody": {
      "type": "object",
      "properties": {
        "collection_id": {"type": "integer", "format": "int64"},
        "title": {"type": "string"},
        "category": {"type": "string"},
        "metadata": {"type": "object"}
      }
    },
    "Collection": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "format": "int64"},
        "user_id": {"type": "integer", "format": "int64"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "item_count": {"type": "integer", "format": "int64"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "CollectionListResult": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {"$ref": "#/definitions/Collection"}
        },
        "total": {"type": "integer", "format": "int64"},
        "page": {"type": "integer"},
        "page_size": {"type": "integer"}
      }
    },
    "CreateCollectionBody": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "is_public": {"type": "boolean"},
        "category": {"type": "string"}
      }
    },
    "ImportItemsResult": {
      "type": "object",
      "properties": {
        "created": {"type": "integer"},
        "updated": {"type": "integer"},
        "errors": {
          "type": "array",
          "items": {"type": "object"}
        }
      }
    },
    "PublicUser": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "format": "int64"},
        "username": {"type": "string"},
        "display_name": {"type": "string"},
        "first_name": {"type": "string"},
        "last_name": {"type": "string"},
        "location": {"type": "string"},
        "bio": {"type": "string"},
        "avatar_url": {"type": "string"},
        "banner_url": {"type": "string"},
        "social_links": {"type": "array", "items": {"type": "object"}},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "MetadataLookupResult": {
      "type": "object",
      "properties": {
        "source": {"type": "string"},
        "query": {"type": "string"},
        "stub": {"type": "boolean"},
        "message": {"type": "string"},
        "results": {"type": "array", "items": {"type": "object"}},
        "preview": {"type": "object"}
      }
    },
    "NotificationUnreadCount": {
      "type": "object",
      "properties": {
        "unread_count": {"type": "integer", "format": "int64"}
      }
    }
  }
}
